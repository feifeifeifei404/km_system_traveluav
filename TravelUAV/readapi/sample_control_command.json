    "armed": true,
    "paused": false
  },
  
  "execution_flow": {
    "steps": [
      {
        "step": 1,
        "action": "enableApiControl(True)",
        "description": "启用API控制"
      },
      {
        "step": 2,
        "action": "armDisarm(True)",
        "description": "解锁电机"
      },
      {
        "step": 3,
        "action": "simPause(False)",
        "description": "取消暂停模拟"
      },
      {
        "step": 4,
        "action": "moveOnPathAsync(path, velocity, ...)",
        "description": "执行航点移动命令"
      },
      {
        "step": 5,
        "action": "监控移动状态",
        "description": "等待到达目标或检测碰撞"
      },
      {
        "step": 6,
        "action": "simPause(True)",
        "description": "到达后暂停模拟"
      }
    ]
  },
  
  "monitoring": {
    "description": "执行过程中的监控机制",
    "checks": [
      {
        "type": "distance_check",
        "condition": "distance_to_target < threshold",
        "threshold": 0.5,
        "threshold_unit": "meters",
        "action": "停止移动，进入下一步"
      },
      {
        "type": "collision_check",
        "condition": "has_collided == True",
        "action": "停止移动，标记失败"
      },
      {
        "type": "stuck_check",
        "condition": "delta_distance < 0.1 for 20 frames",
        "action": "停止移动，标记卡住"
      },
      {
        "type": "timeout_check",
        "condition": "time_elapsed > 5 seconds",
        "action": "停止移动，标记超时"
      }
    ]
  },
  
  "coordinate_system": {
    "system": "AirSim世界坐标系",
    "convention": "NED (North-East-Down)",
    "note": "所有坐标都是绝对世界坐标"
  },
  
  "example_api_usage": {
    "python_code": [
      "import airsim",
      "",
      "client = airsim.MultirotorClient(ip='127.0.0.1', port=30001)",
      "client.confirmConnection()",
      "",
      "# 启用控制",
      "client.enableApiControl(True)",
      "client.armDisarm(True)",
      "client.simPause(False)",
      "",
      "# 构造航点路径",
      "path = [",
      "    airsim.Vector3r(127.0, -90.5, -45.0),",
      "    airsim.Vector3r(128.5, -91.2, -44.8),",
      "    airsim.Vector3r(130.0, -91.8, -44.5),",
      "    airsim.Vector3r(131.5, -91.9, -44.3),",
      "    airsim.Vector3r(132.79, -91.79, -44.20)",
      "]",
      "",
      "# 执行移动",
      "client.moveOnPathAsync(",
      "    path=path,",
      "    velocity=1.0,",
      "    drivetrain=airsim.DrivetrainType.ForwardOnly,",
      "    yaw_mode=airsim.YawMode(is_rate=False),",
      "    lookahead=3,",
      "    adaptive_lookahead=1",
      ").join()",
      "",
      "# 暂停",
      "client.simPause(True)"
    ]
  },
  
  "response_monitoring": {
    "description": "执行后获取的反馈信息",
    "state_query": {
      "api_call": "client.getMultirotorState()",
      "returns": {
        "position": "当前位置",
        "orientation": "当前姿态",
        "velocity": "当前速度",
        "collision": "碰撞信息"
      }
    }
  }
}

